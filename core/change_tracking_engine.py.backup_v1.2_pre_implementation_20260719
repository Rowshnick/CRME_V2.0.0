        )

    # =========================================================
    # FILE SNAPSHOT
    # =========================================================

    def snapshot_file(
        self,
        file_path,
    ):

        file_path = Path(
            file_path
        )

        if not file_path.is_absolute():

            file_path = (
                self.base_path
                / file_path
            )

        if not file_path.exists():

            return {

                "exists": False,

                "path": str(
                    file_path
                ),
            }

        content = (
            file_path.read_bytes()
        )

        return {

            "exists": True,

            "path": str(
                file_path
            ),

            "size": len(
                content
            ),

            "sha256": hashlib.sha256(
                content
            ).hexdigest(),

            "modified_at": datetime.fromtimestamp(
                file_path.stat().st_mtime,
                timezone.utc,
            ).isoformat(),
        }

    # =========================================================
    # FILE CHANGE TRACKING
    # =========================================================

    def track_file_change(
        self,
        file_path,
        before_snapshot,
        after_snapshot,
        session_id=None,
        description="",
    ):

        before_exists = (
            before_snapshot.get(
                "exists",
                False,
            )
        )

        after_exists = (
            after_snapshot.get(
                "exists",
                False,
            )
        )

        if (
            not before_exists
            and after_exists
        ):

            change_type = (
                "ADDED"
            )

        elif (
            before_exists
            and not after_exists
        ):

            change_type = (
                "REMOVED"
            )

        elif (
            before_snapshot.get(
                "sha256"
            )
            != after_snapshot.get(
                "sha256"
            )
        ):

            change_type = (
                "MODIFIED"
            )

        else:

            change_type = (
                "UNCHANGED"
            )

        event = {

            "change_id": (
                "CHG-"
                + datetime.now(
                    timezone.utc
                ).strftime(
                    "%Y%m%d%H%M%S%f"
                )
            ),

            "project_id": (
                self.project_id
            ),

            "engine_version": (
                self.VERSION
            ),

            "timestamp": self._now(),

            "session_id": session_id,

            "description": description,

            "source": "file_tracking",

            "affected_files": [
                str(
                    file_path
                )
            ],

            "file_change": {

                "path": str(
                    file_path
                ),

                "change_type": (
                    change_type
                ),

                "before": (
                    before_snapshot
                ),

                "after": (
                    after_snapshot
                ),
            },

            "summary": {

                "total_changes": (
                    0
                    if change_type
                    == "UNCHANGED"
                    else 1
                ),

                "added": (
                    1
                    if change_type
                    == "ADDED"
                    else 0
                ),

                "removed": (
                    1
                    if change_type
                    == "REMOVED"
                    else 0
                ),

                "modified": (
                    1
                    if change_type
                    == "MODIFIED"
                    else 0
                ),

                "fundamental": 0,

                "structural": 0,
            },

            "changes": [],

            "fundamental_changes": [],

            "structural_changes": [],
        }

        return self.record_change(
            event
        )

    # =========================================================
    # QUERY API
    # =========================================================

    def get_all_changes(
        self,
    ):

        log = (
            self._load_json(
                self.change_log_path
            )
        )

        if not log:

            return []

        return log.get(
            "changes",
            [],
        )

    def get_session_changes(
        self,
        session_id,
    ):

        return [

            change

            for change in
            self.get_all_changes()

            if change.get(
                "session_id"
            )
            == session_id
        ]

    def get_fundamental_changes(
        self,
    ):

        return [

            change

            for change in
            self.get_all_changes()

            if change.get(
                "fundamental_changes"
            )
        ]

    def get_structural_changes(
        self,
    ):

        return [

            change

            for change in
            self.get_all_changes()

            if change.get(
                "structural_changes"
            )
        ]

    def get_latest_change(
        self,
    ):

        return self._load_json(
            self.latest_change_path
        )

    def get_index(
        self,
    ):

        return self._load_json(
            self.change_index_path
        )

    # =========================================================
    # RECONSTRUCTION
    # =========================================================

    def reconstruct_state(
        self,
        change_id=None,
    ):

        changes = (
            self.get_all_changes()
        )

        if not changes:

            return None

        if change_id:

            selected = None

            for event in changes:

                if (
                    event.get(
                        "change_id"
                    )
                    == change_id
                ):

                    selected = event

                    break

            if selected is None:

                return None

            return deepcopy(
                selected.get(
                    "after_snapshot"
                )
            )

        latest = changes[-1]

        return deepcopy(
            latest.get(
                "after_snapshot"
            )
        )

    # =========================================================
    # SUMMARY
    # =========================================================

    def summary(
        self,
    ):

        index = (
            self.get_index()
        )

        if not index:

            return {

                "project_id": (
                    self.project_id
                ),

                "total_changes": 0,
            }

        return {

            "project_id": (
                self.project_id
            ),

            "engine_version": (
                self.VERSION
            ),

            "total_changes": (
                index.get(
                    "total_changes",
                    0,
                )
            ),

            "fundamental_changes": (
                index.get(
                    "fundamental_changes",
                    0,
                )
            ),

            "structural_changes": (
                index.get(
                    "structural_changes",
                    0,
                )
            ),

            "sessions_with_changes": len(
                index.get(
                    "sessions",
                    {}
                )
            ),

            "change_types": (
                index.get(
                    "change_types",
                    {}
                )
            ),

            "tracked_paths": len(
                index.get(
                    "files",
                    {}
                )
            ),
        }


    # =========================================================
    # v1.1 LIST-LEVEL CHANGE ANALYSIS
    # =========================================================

    def _list_difference(
        self,
        before,
        after,
    ):
        """
        Detect added, removed, and retained items
        in list-like structures.

        Order is ignored for change classification.
        """

        before = (
            before
            if isinstance(before, list)
            else []
        )

        after = (
            after
            if isinstance(after, list)
            else []
        )

        before_set = {
            self._canonical_json(item)
            for item in before
        }

        after_set = {
            self._canonical_json(item)
            for item in after
        }

        added = [
            item
            for item in after
            if self._canonical_json(item)
            not in before_set
        ]

        removed = [
            item
            for item in before
            if self._canonical_json(item)
            not in after_set
        ]

        retained = [
            item
            for item in after
            if self._canonical_json(item)
            in before_set
        ]

        return {
            "added": added,
            "removed": removed,
            "retained": retained,
            "added_count": len(added),
            "removed_count": len(removed),
            "retained_count": len(retained),
        }

    def analyze_list_change(
        self,
        path,
        before,
        after,
    ):
        """
        Analyze a list change at item level.
        """

        diff = self._list_difference(
            before,
            after,
        )

        if (
            diff["added_count"] == 0
            and diff["removed_count"] == 0
        ):

            return {
                "path": path,
                "change_type": "UNCHANGED",
                "impact": "LOW",
                "added": [],
                "removed": [],
                "retained": diff["retained"],
                "summary": diff,
            }

        if (
            self._is_fundamental_key(
                path.split(".")[-1]
            )
        ):

            change_type = "FUNDAMENTAL"
            impact = "HIGH"

        elif (
            self._is_structural_key(
                path.split(".")[-1]
            )
        ):

            change_type = "STRUCTURAL"
            impact = "MEDIUM"

        else:

            change_type = "MODIFIED"
            impact = "LOW"

        return {
            "path": path,
            "change_type": change_type,
            "impact": impact,
            "added": diff["added"],
            "removed": diff["removed"],
            "retained": diff["retained"],
            "summary": diff,
        }

    # =========================================================
    # v1.1 IMPACT ANALYSIS
    # =========================================================

    def calculate_change_impact(
        self,
        change,
    ):
        """
        Estimate change impact.

        HIGH
            Fundamental research or project change.

        MEDIUM
            Structural architecture or evaluation change.

        LOW
            Local implementation modification.
        """

        change_type = (
            change.get(
                "change_type"
            )
        )

        path = str(
            change.get(
                "path",
                ""
            )
        ).lower()

        if (
            change_type
            == "FUNDAMENTAL"
        ):

            return "HIGH"

        fundamental_tokens = (
            "research_question",
            "research_problem",
            "methodology",
            "evaluation_protocol",
            "project_goal",
            "paper_claims",
            "architecture",
        )

        if any(
            token in path
            for token in fundamental_tokens
        ):

            return "HIGH"

        if (
            change_type
            == "STRUCTURAL"
        ):

            return "MEDIUM"

        structural_tokens = (
            "modules",
            "components",
            "files",
            "dependencies",
            "datasets",
            "experiments",
            "evaluation",
        )

        if any(
            token in path
            for token in structural_tokens
        ):

            return "MEDIUM"

        return "LOW"

    # =========================================================
    # v1.1 CHANGE ENRICHMENT
    # =========================================================

    def enrich_changes(
        self,
        changes,
    ):
        """
        Add impact metadata to every detected change.
        """

        enriched = []

        for change in changes:

            item = deepcopy(
                change
            )

            item[
                "impact"
            ] = self.calculate_change_impact(
                item
            )

            enriched.append(
                item
            )

        return enriched

    # =========================================================
    # v1.1 SESSION CHANGE REPORT
    # =========================================================

    def generate_session_change_report(
        self,
        session_id,
    ):
        """
        Generate a compact change report for one session.
        """

        changes = (
            self.get_session_changes(
                session_id
            )
        )

        fundamental = []
        structural = []
        modified = []
        added = []
        removed = []

        for event in changes:

            for change in event.get(
                "changes",
                [],
            ):

                change_type = (
                    change.get(
                        "change_type"
                    )
                )

                if change_type == "FUNDAMENTAL":
                    fundamental.append(
                        change
                    )

                elif change_type == "STRUCTURAL":
                    structural.append(
                        change
                    )

                elif change_type == "MODIFIED":
                    modified.append(
                        change
                    )

                elif change_type == "ADDED":
                    added.append(
                        change
                    )

                elif change_type == "REMOVED":
                    removed.append(
                        change
                    )

        return {
            "project_id": self.project_id,
            "session_id": session_id,
            "total_events": len(changes),
            "fundamental_changes": fundamental,
            "structural_changes": structural,
            "modified_changes": modified,
            "added_changes": added,
            "removed_changes": removed,
            "summary": {
                "fundamental": len(fundamental),
                "structural": len(structural),
                "modified": len(modified),
                "added": len(added),
                "removed": len(removed),
            },
        }


