        }


    # =====================================================
    # UTIL
    # =====================================================

    def _now(
        self
    ):

        return datetime.now(
            timezone.utc
        ).isoformat()



    def _deduplicate(self, results):
        """
        Remove duplicate search results while preserving ranking order.

        Duplicate identity is determined by:
        1. Explicit result id when available
        2. Session/artifact/object identity
        3. Normalized text fallback
        """

        if not results:
            return []

        unique = []
        seen = set()

        for result in results:
            if not isinstance(result, dict):
                continue

            data = result.get("data") or {}

            identity = (
                result.get("id")
                or result.get("result_id")
                or data.get("id")
                or data.get("session_id")
                or data.get("artifact_id")
                or data.get("object_id")
            )

            if identity is not None:
                key = (
                    result.get("type", ""),
                    str(identity)
                )
            else:
                text_value = result.get("text", "")

                if isinstance(text_value, str):
                    normalized = " ".join(
                        text_value.lower().split()
                    )
                else:
                    normalized = str(text_value)

                key = (
                    result.get("type", ""),
                    normalized
                )

            if key in seen:
                continue

            seen.add(key)
            unique.append(result)

        return unique

